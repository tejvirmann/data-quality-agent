{
  "version": 2,
  "builds": [
    {
      "src": "api/mcp.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "250mb",
        "maxDuration": 60
      }
    },
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    { "src": "/mcp(.*)", "dest": "/api/mcp.py" },
    { "src": "/", "dest": "/api/index.py" }
  ]
}
